# LLM_Project & CLAY Specific
# ==========================================
# Ignore Python Virtual Environment
LLM_Project/llm_env/

# Ignore large datasets
LLM_Project/CLAY/data/

# Strictly forbid uploading large model weights (Checkpoints)
*.ckpt
*.safetensors

# Ignore fine-tuned LoRA weights and classifier heads
LLM_Project/CLAY/saved_lora_best/

# Ignore output pictures but keep the directory structure
LLM_Project/CLAY/outputs/*
!LLM_Project/CLAY/outputs/.gitkeep